{
  "name": "a3-bskulls",
  "runArgs": [
    "--name",
    "a3-bskulls"
  ],
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/a3-bskulls,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/a3-bskulls",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "stable"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    {
      "source": "a3-bskulls-claude",
      "target": "/home/vscode/.claude",
      "type": "volume"
    },
    {
      "source": "a3-bskulls-codex",
      "target": "/home/vscode/.codex",
      "type": "volume"
    },
    {
      "source": "a3-bskulls-vscode-server",
      "target": "/home/vscode/.vscode-server",
      "type": "volume"
    }
  ],
  "postStartCommand": "sudo chown -R vscode:vscode /home/vscode/.claude /home/vscode/.codex && sudo chmod -R a+rwX /home/vscode/.vscode-server",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/post-attach.sh",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CODEX_HOME": "/home/vscode/.codex",
    "XDG_CACHE_HOME": "/tmp/xdg-cache",
    "XDG_DATA_HOME": "/tmp/xdg-data"
  },
  "remoteEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CODEX_HOME": "/home/vscode/.codex",
    "XDG_CACHE_HOME": "/tmp/xdg-cache",
    "XDG_DATA_HOME": "/tmp/xdg-data"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "Armitxes.sqf",
        "clevermonkey.claude-monkey-bar",
        "codezombiech.gitignore",
        "davidanson.vscode-markdownlint",
        "eamodio.gitlens",
        "editorconfig.editorconfig",
        "foxundermoon.shell-format",
        "github.vscode-github-actions",
        "wdhongtw.gpg-indicator",
        "jasonnutter.vscode-codeowners",
        "ms-vscode.cpptools",
        "ole1986.arma-dev",
        "openai.chatgpt",
        "pkief.material-icon-theme",
        "redhat.vscode-yaml",
        "shd101wyy.markdown-preview-enhanced",
        "skacekachna.sqflint",
        "tamasfe.even-better-toml",
        "BrettMayson.hemtt",
        "vlad333000.sqf",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "files.eol": "\n"
      }
    }
  }
}
