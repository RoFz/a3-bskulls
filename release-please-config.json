      "version-file": "version.txt",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "addons/bskulls-modern/CfgPatches.hpp"
        },
        {
          "type": "generic",
          "path": ".hemtt/project.toml"
        }
      ]
    },
    "bskulls-nam": {
      "release-type": "simple",
      "component": "bskulls-nam",
      "include-component-in-tag": true,
      "include-v-in-tag": true,
      "tag-separator": "-",
      "initial-version": "0.1.0",
      "version-file": "version.txt",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "addons/bskulls-nam/CfgPatches.hpp"
        },
        {
          "type": "generic",
          "path": ".hemtt/project.toml"
        }
      ]
    }
  }
}
